# Lokalni store za Coolify ENV bundle (build-coolify-env.sh).
# Kopiraj u .coolify-secrets.env (GITIGNORED) i popuni. NIKAD ne commitaj popunjenu verziju.
#
#   cp .coolify-secrets.env.example .coolify-secrets.env
#   # popuni vrijednosti
#   ./scripts/build-coolify-env.sh        # → ENV bundle u clipboardu za Coolify

# --- OBAVEZNO: iz Certilia developer portala (Show Config) ---
CERTILIA_CLIENT_ID=
CERTILIA_CLIENT_SECRET=

# --- OBAVEZNO: tvoja deployana domena proxyja ---
PRODUCTION_URL=https://certilia.domovina.ai
CERTILIA_REDIRECT_URI=https://certilia.domovina.ai/api/auth/callback
# Origini Flutter app-a (bez trailing slash); uključi i localhost za dev:
ALLOWED_ORIGINS=https://domovina.ai,https://www.domovina.ai,http://localhost:5173

# --- OPCIONALNO: ostavi prazno → build-coolify-env.sh generira fresh + spremi ovdje ---
JWT_SECRET=
SESSION_SECRET=

# --- OPCIONALNO override-i (default je PROD Certilia) ---
# Za TEST IDP: https://idp.test.certilia.com
# CERTILIA_BASE_URL=https://idp.certilia.com
